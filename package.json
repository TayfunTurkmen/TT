{
  "name": "tayfun-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "build:next": "next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "d1:migrate:local": "wrangler d1 execute tayfun-blog-db --local --file ./migrations/0001_auto_blog_runs.sql",
    "d1:migrate:remote": "wrangler d1 execute tayfun-blog-db --remote --file ./migrations/0001_auto_blog_runs.sql",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@swc/helpers": "0.5.21",
    "ai": "^6.0.160",
    "gray-matter": "^4.0.3",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "@swc/helpers": "0.5.21"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
